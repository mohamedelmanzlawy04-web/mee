# ─────────────────────────────────────────────────────────────────────────────
# STRESSNES — Railway environment variables
# Copy this file to .env for local development (never commit .env).
# On Railway, set these in the service's Variables tab.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (required) ───────────────────────────────────────────────────────
# Add a Railway Postgres plugin and Railway sets this automatically via the
# reference variable ${{Postgres.DATABASE_URL}}.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Authentication (required) ─────────────────────────────────────────────────
# Used to sign JWT session cookies. Must be a strong secret (≥ 32 characters).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-secret

# ── Telegram order notifications (optional) ───────────────────────────────────
# Leave blank to disable. When set, a Telegram message is sent on every
# successful order (server-side only — the token is never exposed to the client).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Only needed if the frontend is hosted on a different domain than the API.
# In the default single-service Railway deployment the frontend is served by
# the same Express process, so this can remain empty.
# Example (multiple origins): https://stressnes.com,https://www.stressnes.com
CORS_ORIGIN=

# ── Object / Media Storage ────────────────────────────────────────────────────
# ⚠️  The current storage implementation uses Replit's managed GCS sidecar
#     (a local HTTP service at 127.0.0.1:1106) and will NOT work on Railway.
#     Product image uploads will be unavailable until the storage layer is
#     replaced with a standard provider (AWS S3, Cloudflare R2, etc.).
#     See artifacts/api-server/src/lib/objectStorage.ts to adapt it.
#
# PUBLIC_OBJECT_SEARCH_PATHS=
# PRIVATE_OBJECT_DIR=

# ── Node (set automatically by the Dockerfile) ────────────────────────────────
NODE_ENV=production
# Do NOT set PORT here — Railway injects it automatically.
