# ─────────────────────────────────────────────────────────────────────────────
# STRESSNES — Railway environment variables
# Copy this file, fill in the values, and paste them into your Railway service's
# "Variables" tab. Every variable marked REQUIRED must be set before deploying.
# ─────────────────────────────────────────────────────────────────────────────

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=production

# PORT is injected automatically by Railway — do not set it manually.

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
# REQUIRED. Use Railway's built-in Postgres plugin or any external Postgres URL.
# Railway template: postgresql://${{Postgres.PGUSER}}:${{Postgres.PGPASSWORD}}@${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Session & Auth ────────────────────────────────────────────────────────────
# REQUIRED. At least 32 random characters. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-32-char-string

# ── CORS ──────────────────────────────────────────────────────────────────────
# REQUIRED. The public URL of your Railway deployment (no trailing slash).
# The API and frontend are served from the same container, so same-origin
# requests don't need CORS — but set this so other clients (mobile apps, etc.)
# can reach the API.
CORS_ORIGIN=https://your-app.up.railway.app

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# REQUIRED. Get from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=123456789:ABCdef...

# REQUIRED. Your Telegram user ID or group chat ID (negative number for groups).
# Get your user ID by messaging @userinfobot on Telegram.
TELEGRAM_CHAT_ID=123456789

# REQUIRED. The public URL of your Railway deployment (same as CORS_ORIGIN).
# Used to register the Telegram webhook endpoint on startup.
APP_DOMAIN=your-app.up.railway.app

# ── Google Cloud Storage ───────────────────────────────────────────────────────
# REQUIRED if you use product image uploads or payment screenshot uploads.
#
# 1. Create a GCS bucket in Google Cloud Console.
# 2. Create a service account with the "Storage Admin" role on the bucket.
# 3. Download the JSON key file and paste its entire contents as the value below
#    (collapse to a single line or use Railway's multiline variable support).
GCS_CREDENTIALS={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"stressnes@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# REQUIRED if using object storage.
# Comma-separated GCS paths where public assets (product images) are stored.
# Format: /bucket-name/folder
PUBLIC_OBJECT_SEARCH_PATHS=/your-bucket/public/products,/your-bucket/public/assets

# REQUIRED if using object storage.
# GCS path prefix where private uploads (payment screenshots) are stored.
PRIVATE_OBJECT_DIR=/your-bucket/private

# ─────────────────────────────────────────────────────────────────────────────
# After setting all variables:
#   1. Run database migrations: pnpm --filter @workspace/db run push
#   2. Run seeds (first deploy only):
#        pnpm --filter @workspace/scripts run seed
#        pnpm --filter @workspace/scripts run seed:gov
#        pnpm --filter @workspace/scripts run seed:admin
# ─────────────────────────────────────────────────────────────────────────────
