// ============================================================
// STRESSNES — Prisma Schema
// Task 2: Complete Database Architecture
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  CUSTOMER
  ADMIN
  MODERATOR
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  PAYMOB
  STRIPE
  CASH_ON_DELIVERY
}

enum TransactionType {
  CHARGE
  REFUND
  PARTIAL_REFUND
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InventoryChangeReason {
  PURCHASE       // Customer order placed
  RETURN         // Customer return
  ADJUSTMENT     // Manual stock adjustment
  RESERVATION    // Stock reserved for pending order
  RELEASE        // Reservation released (order cancelled)
  DAMAGE         // Damaged/lost inventory
  RESTOCK        // Restocked from supplier
}

enum ShippingCarrier {
  BOSTA
  MYLERZ
  ARAMEX
  MANUAL
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  RESOLVED
}

// ============================================================
// USER & AUTH
// ============================================================

/// Customers, admins, and moderators of the STRESSNES platform.
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?
  fullName      String
  phone         String?
  role          UserRole  @default(CUSTOMER)
  emailVerified DateTime?
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // Soft delete

  // NextAuth OAuth accounts
  accounts      Account[]

  // Relations
  addresses     Address[]
  orders        Order[]
  cart          Cart?
  wishlist      Wishlist?
  reviews       Review[]
  couponUsages  CouponUsage[]

  @@index([email])
  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

/// NextAuth OAuth provider accounts (Google, Facebook, etc.)
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

/// NextAuth email verification tokens.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// Customer shipping and billing addresses.
model Address {
  id         String   @id @default(uuid())
  userId     String
  firstName  String
  lastName   String
  line1      String
  line2      String?
  city       String
  state      String?
  postalCode String
  country    String   @default("EG")
  phone      String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

// ============================================================
// PRODUCT CATALOG
// ============================================================

/// Top-level product categories (e.g., Tops, Bottoms, Outerwear).
model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subCategories SubCategory[]
  products      Product[]

  @@index([slug])
  @@index([isActive])
  @@map("categories")
}

/// Subcategories belonging to a parent Category.
model SubCategory {
  id          String   @id @default(uuid())
  categoryId  String
  name        String
  slug        String   @unique
  description String?
  image       String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([categoryId])
  @@index([slug])
  @@map("sub_categories")
}

/// Curated collections (Summer, Core, Limited, etc.)
model Collection {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@index([slug])
  @@index([isActive])
  @@map("collections")
}

/// Tags for flexible product labeling (e.g., "new-arrival", "sale").
model ProductTag {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  products Product[]

  @@map("product_tags")
}

/// Core product entity with SEO and pricing fields.
model Product {
  id               String        @id @default(uuid())
  title            String
  slug             String        @unique
  description      String?       @db.Text
  shortDescription String?
  sku              String        @unique
  barcode          String?       @unique
  price            Decimal       @db.Decimal(10, 2)
  comparePrice     Decimal?      @db.Decimal(10, 2)
  costPrice        Decimal?      @db.Decimal(10, 2)
  status           ProductStatus @default(DRAFT)
  featured         Boolean       @default(false)
  published        Boolean       @default(false)
  weight           Decimal?      @db.Decimal(8, 3) // kg
  seoTitle         String?
  seoDescription   String?
  metaKeywords     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?     // Soft delete

  // Catalog relations
  categoryId    String?
  subCategoryId String?
  collectionId  String?

  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subCategory SubCategory? @relation(fields: [subCategoryId], references: [id], onDelete: SetNull)
  collection  Collection?  @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  tags        ProductTag[]

  // Product details
  variants  ProductVariant[]
  images    ProductImage[]
  reviews   Review[]

  // Cart and wishlist
  cartItems     CartItem[]
  wishlistItems WishlistItem[]

  @@index([slug])
  @@index([status])
  @@index([published])
  @@index([featured])
  @@index([categoryId])
  @@index([collectionId])
  @@index([deletedAt])
  @@index([price])
  @@map("products")
}

/// Product size/color/material variants with their own SKU and pricing.
model ProductVariant {
  id            String   @id @default(uuid())
  productId     String
  sku           String   @unique
  size          String?
  color         String?
  material      String?
  priceOverride Decimal? @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  inventory     Inventory?
  cartItems     CartItem[]
  wishlistItems WishlistItem[]
  orderItems    OrderItem[]

  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

/// Cloudinary-hosted product images with sort order.
model ProductImage {
  id                String   @id @default(uuid())
  productId         String
  cloudinaryPublicId String?
  url               String
  altText           String?
  sortOrder         Int      @default(0)
  isPrimary         Boolean  @default(false)
  createdAt         DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isPrimary])
  @@map("product_images")
}

// ============================================================
// INVENTORY
// ============================================================

/// Real-time stock levels per product variant.
model Inventory {
  id                String   @id @default(uuid())
  variantId         String   @unique
  currentStock      Int      @default(0)
  reservedStock     Int      @default(0)  // Held for pending orders
  lowStockThreshold Int      @default(5)
  trackInventory    Boolean  @default(true)
  updatedAt         DateTime @updatedAt

  variant  ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  history  InventoryHistory[]

  // Computed: availableStock = currentStock - reservedStock
  @@index([currentStock])
  @@map("inventories")
}

/// Audit trail of all stock changes.
model InventoryHistory {
  id            String                @id @default(uuid())
  inventoryId   String
  change        Int                   // Positive = increase, negative = decrease
  reason        InventoryChangeReason
  previousStock Int
  newStock      Int
  note          String?
  orderId       String?               // Reference order if applicable
  createdAt     DateTime              @default(now())

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([inventoryId])
  @@index([createdAt])
  @@map("inventory_history")
}

// ============================================================
// CART & WISHLIST
// ============================================================

/// Shopping cart — supports both authenticated users and guests (via sessionId).
model Cart {
  id        String    @id @default(uuid())
  userId    String?   @unique
  sessionId String?   @unique // For guest carts
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([sessionId])
  @@index([expiresAt])
  @@map("carts")
}

/// Individual line items within a cart.
model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int      @default(1)
  price     Decimal  @db.Decimal(10, 2) // Price at time of adding
  addedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([cartId, productId, variantId])
  @@index([cartId])
  @@map("cart_items")
}

/// Customer saved wishlist (one per user).
model Wishlist {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WishlistItem[]

  @@map("wishlists")
}

/// Items saved to a customer wishlist.
model WishlistItem {
  id        String   @id @default(uuid())
  wishlistId String
  productId String
  variantId String?
  addedAt   DateTime @default(now())

  wishlist Wishlist       @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product  Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant  ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([wishlistId, productId, variantId])
  @@index([wishlistId])
  @@map("wishlist_items")
}

// ============================================================
// ORDERS
// ============================================================

/// Customer order with address snapshots to preserve order history.
model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique
  userId          String
  status          OrderStatus @default(PENDING)

  // Pricing
  subtotal        Decimal     @db.Decimal(10, 2)
  discountAmount  Decimal     @db.Decimal(10, 2) @default(0)
  taxAmount       Decimal     @db.Decimal(10, 2) @default(0)
  shippingCost    Decimal     @db.Decimal(10, 2) @default(0)
  total           Decimal     @db.Decimal(10, 2)
  currency        String      @default("EGP")

  // Address snapshots (JSON to preserve at order time)
  shippingAddress Json
  billingAddress  Json?

  // Coupon
  couponId        String?
  couponCode      String?

  // Shipping
  shippingMethod  String?
  trackingNumber  String?
  shippingCarrier ShippingCarrier?

  // Meta
  notes           String?     @db.Text
  cancelledReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?   // Soft delete

  user         User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  items        OrderItem[]
  payments     Payment[]
  couponUsages CouponUsage[]

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("orders")
}

/// Immutable snapshot of a product variant at the time of ordering.
model OrderItem {
  id String @id @default(uuid())

  orderId   String
  productId String
  variantId String?

  // Snapshots — frozen at purchase time
  productName     String
  variantSnapshot Json?   // { size, color, material, sku }
  unitPrice       Decimal @db.Decimal(10, 2)
  quantity        Int
  discountAmount  Decimal @db.Decimal(10, 2) @default(0)
  total           Decimal @db.Decimal(10, 2)

  // Cloudinary image at time of purchase
  productImage String?

  createdAt DateTime @default(now())

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ============================================================
// PAYMENTS & TRANSACTIONS
// ============================================================

/// Payment record per order — supports multiple providers.
model Payment {
  id              String          @id @default(uuid())
  orderId         String
  provider        PaymentProvider
  transactionId   String?         @unique // Gateway-assigned ID
  status          PaymentStatus   @default(PENDING)
  amount          Decimal         @db.Decimal(10, 2)
  currency        String          @default("EGP")
  gatewayResponse Json?           // Raw response from payment gateway
  failureReason   String?
  paidAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([orderId])
  @@index([status])
  @@index([transactionId])
  @@map("payments")
}

/// Individual financial transactions linked to a payment.
model Transaction {
  id        String          @id @default(uuid())
  paymentId String
  type      TransactionType
  amount    Decimal         @db.Decimal(10, 2)
  currency  String          @default("EGP")
  status    PaymentStatus   @default(PENDING)
  metadata  Json?
  createdAt DateTime        @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("transactions")
}

// ============================================================
// COUPONS & DISCOUNTS
// ============================================================

/// Discount coupons supporting percentage and fixed-amount types.
model Coupon {
  id           String     @id @default(uuid())
  code         String     @unique
  type         CouponType
  value        Decimal    @db.Decimal(10, 2) // Percentage (0-100) or fixed EGP amount
  minSpend     Decimal?   @db.Decimal(10, 2) // Minimum order amount to apply
  maxDiscount  Decimal?   @db.Decimal(10, 2) // Cap on percentage discounts
  usageLimit   Int?       // Total uses allowed (null = unlimited)
  perUserLimit Int        @default(1)          // Max uses per customer
  usedCount    Int        @default(0)
  isActive     Boolean    @default(true)
  expiresAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  usages CouponUsage[]

  @@index([code])
  @@index([isActive])
  @@index([expiresAt])
  @@map("coupons")
}

/// Tracks which users used which coupons on which orders.
model CouponUsage {
  id       String   @id @default(uuid())
  couponId String
  userId   String
  orderId  String
  usedAt   DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([couponId, orderId])
  @@index([couponId])
  @@index([userId])
  @@map("coupon_usages")
}

// ============================================================
// REVIEWS
// ============================================================

/// Customer product reviews with verified-purchase flag.
model Review {
  id              String       @id @default(uuid())
  userId          String
  productId       String
  orderId         String?      // Null for non-verified reviews
  rating          Int          // 1–5
  comment         String?      @db.Text
  verifiedPurchase Boolean     @default(false)
  status          ReviewStatus @default(PENDING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  images  ReviewImage[]

  @@unique([userId, productId, orderId]) // One review per purchase
  @@index([productId])
  @@index([status])
  @@index([rating])
  @@map("reviews")
}

/// Images attached to customer reviews.
model ReviewImage {
  id                 String   @id @default(uuid())
  reviewId           String
  cloudinaryPublicId String?
  url                String
  createdAt          DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_images")
}

// ============================================================
// SHIPPING
// ============================================================

/// Available shipping methods with carrier and pricing.
model ShippingMethod {
  id             String          @id @default(uuid())
  name           String
  carrier        ShippingCarrier
  price          Decimal         @db.Decimal(10, 2)
  estimatedDays  Int             // Estimated delivery days
  isActive       Boolean         @default(true)
  minOrderAmount Decimal?        @db.Decimal(10, 2) // Free shipping threshold
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([isActive])
  @@index([carrier])
  @@map("shipping_methods")
}

// ============================================================
// MARKETING & SUPPORT
// ============================================================

/// Newsletter email subscribers.
model NewsletterSubscriber {
  id           String    @id @default(uuid())
  email        String    @unique
  isActive     Boolean   @default(true)
  subscribedAt DateTime  @default(now())
  unsubscribedAt DateTime?

  @@index([email])
  @@index([isActive])
  @@map("newsletter_subscribers")
}

/// Customer support contact form submissions.
model ContactMessage {
  id        String        @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String        @db.Text
  status    ContactStatus @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("contact_messages")
}
